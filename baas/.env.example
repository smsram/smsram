# ==============================================================================
# SMSRam BaaS Cluster - Local Environment Configuration
# ==============================================================================

# 1. Backblaze B2 Cloud Storage Configuration
B2_KEY_ID=your_backblaze_key_id_here
B2_APPLICATION_KEY=your_backblaze_application_key_here
B2_BUCKET=your_b2_bucket_name_here
B2_ENDPOINT=your_b2_s3_endpoint_url_here

# 2. Base Ecosystem Authentication & Authorization
MASTER_ADMIN_KEY=your_chosen_secure_admin_password_here
JWT_SECRET=your_generated_random_jwt_secret_string_here
HF_TOKEN=your_hugging_face_write_access_token_here

# 3. Third-Party AI Model Provider Routing Engine Keys
CEREBRAS_API_KEY=your_cerebras_secret_key_here
SILICONFLOW_API_KEY=your_siliconflow_secret_key_here
MISTRAL_API_KEY=your_mistral_client_secret_here
DEEPSEEK_API_KEY=your_deepseek_secret_key_here
ZHIPU_API_KEY=your_zhipu_ai_secret_key_here

# 4. Cloudflare Worker Framework Contexts
CF_ACCOUNT_ID=your_cloudflare_account_hash_id_here
CF_API_TOKEN=your_cloudflare_scoped_api_token_here

# 5. Local Network Port Override (Optional)
PORT=5000